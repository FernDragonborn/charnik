{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": ["tools/**/*.mjs"],
  "project": ["src/**/*.{ts,svelte}", "tools/**/*.mjs"],
  "ignore": ["src/lib/index.ts"],
  "ignoreDependencies": ["@tauri-apps/cli", "@tauri-apps/plugin-dialog"],
  "rules": {
    "exports": "warn",
    "types": "warn",
    "enumMembers": "warn",
    "duplicates": "warn"
  }
}
