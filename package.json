{
	"name": "charnik",
	"private": true,
	"version": "0.0.1",
	"license": "AGPL-3.0-or-later",
	"type": "module",
	"packageManager": "pnpm@11.3.0",
	"scripts": {
		"content:static": "node tools/build-static-content.mjs",
		"predev": "node tools/build-static-content.mjs",
		"dev": "vite dev",
		"prebuild": "node tools/build-static-content.mjs",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint . && stylelint \"src/**/*.{css,svelte}\"",
		"lint:fix": "prettier --write . && eslint . --fix && stylelint \"src/**/*.{css,svelte}\" --fix"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tauri-apps/cli": "^2.11.3",
		"@types/papaparse": "^5.5.2",
		"eslint": "^10.6.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.20.0",
		"fast-check": "^4.8.0",
		"globals": "^17.7.0",
		"postcss-html": "^1.8.1",
		"prettier": "^3.9.0",
		"prettier-plugin-svelte": "^4.1.1",
		"stylelint": "^17.14.0",
		"stylelint-config-standard": "^40.0.0",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.62.1",
		"vite": "^8.0.16",
		"vitest": "^4.1.9"
	},
	"dependencies": {
		"@tauri-apps/plugin-dialog": "~2.7.1",
		"@tauri-apps/plugin-fs": "~2.5.1",
		"dompurify": "^3.4.11",
		"fuse.js": "^7.4.2",
		"marked": "^18.0.5",
		"papaparse": "^5.5.4",
		"svelte-dnd-action": "^0.9.70",
		"svelte-i18n": "^4.0.1",
		"svelte-sonner": "^1.1.1",
		"zod": "^4.4.3"
	}
}
