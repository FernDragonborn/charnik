{
	"name": "charnik",
	"private": true,
	"version": "0.4.0",
	"license": "AGPL-3.0-or-later",
	"type": "module",
	"packageManager": "pnpm@11.3.0",
	"scripts": {
		"content:static": "node tools/build-static-content.mjs",
		"surface": "node tools/surface.mjs",
		"predev": "node tools/build-static-content.mjs",
		"dev": "vite dev",
		"prebuild": "node tools/build-static-content.mjs",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint . && stylelint \"src/**/*.{css,svelte}\" && knip && jscpd",
		"lint:fix": "prettier --write . && eslint . --fix && stylelint \"src/**/*.{css,svelte}\" --fix",
		"knip": "knip",
		"jscpd": "jscpd",
		"postinstall": "simple-git-hooks",
		"plugin:test": "tsx tools/plugin-test.ts"
	},
	"simple-git-hooks": {
		"pre-commit": "node tools/surface.mjs && git add docs/SURFACE.md && npx jscpd"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.70.1",
		"@sveltejs/vite-plugin-svelte": "^7.2.0",
		"@tauri-apps/cli": "^2.11.4",
		"@types/papaparse": "^5.5.2",
		"@vitest/browser": "^4.1.10",
		"@vitest/browser-playwright": "^4.1.10",
		"@vitest/coverage-v8": "^4.1.10",
		"eslint": "^10.7.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.22.0",
		"fake-indexeddb": "^6.2.5",
		"fast-check": "^4.9.0",
		"globals": "^17.7.0",
		"jscpd": "^5.0.12",
		"knip": "^6.27.0",
		"pixelmatch": "^7.2.0",
		"playwright": "^1.61.1",
		"pngjs": "^7.0.0",
		"postcss-html": "^1.8.1",
		"prettier": "^3.9.6",
		"prettier-plugin-svelte": "^4.1.1",
		"simple-git-hooks": "^2.13.1",
		"stylelint": "^17.14.1",
		"stylelint-config-standard": "^40.0.0",
		"svelte": "^5.56.7",
		"svelte-check": "^4.7.3",
		"tsx": "^4.23.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.65.0",
		"vite": "^8.1.5",
		"vitest": "^4.1.10",
		"vitest-browser-svelte": "^2.2.0"
	},
	"dependencies": {
		"@jitl/quickjs-ng-wasmfile-release-sync": "^0.32.0",
		"@tauri-apps/api": "^2.11.1",
		"@tauri-apps/plugin-dialog": "~2.7.2",
		"@tauri-apps/plugin-fs": "~2.5.1",
		"@tauri-apps/plugin-opener": "^2.5.4",
		"@tauri-apps/plugin-process": "^2.3.1",
		"@tauri-apps/plugin-updater": "^2.10.1",
		"dompurify": "^3.4.12",
		"fastest-levenshtein": "^1.0.16",
		"fuse.js": "^7.5.0",
		"idb": "^8.0.3",
		"marked": "^18.0.7",
		"papaparse": "^5.5.4",
		"quickjs-emscripten-core": "^0.32.0",
		"svelte-dnd-action": "^0.9.74",
		"svelte-i18n": "^4.0.1",
		"svelte-sonner": "^1.1.1",
		"xxhash-wasm": "^1.1.0",
		"zod": "^4.4.3"
	}
}
